            "description": "Returns a paginated list of products belonging to the given category slug. Supports optional query params: `page`, `page_size`, and `ordering`."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
