{
  "info": {
    "_postman_id": "luxe-market-collection-v1",
    "name": "Luxe Market API",
    "description": "Complete API collection for the Luxe Market Django 5 e-commerce platform. Covers authentication, product browsing, and category management.\n\n**Setup:**\n1. Set `base_url` to `http://localhost:8000` (already configured).\n2. Call **Login** — the pre-request script auto-saves the access token.\n3. All protected routes use `{{access_token}}` automatically.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "type": "string",
      "description": "Base URL for the Luxe Market API server."
    },
    {
      "key": "access_token",
      "value": "",
      "type": "string",
      "description": "JWT access token. Populated automatically after a successful Login request."
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Endpoints for user registration, login, logout, token refresh, and profile management.",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Sophia\",\n  \"last_name\": \"Bennett\",\n  \"email\": \"sophia.bennett@example.com\",\n  \"password\": \"SecurePass@2024\",\n  \"password_confirm\": \"SecurePass@2024\"\n}"
            },
            "description": "Creates a new user account. Returns the created user object along with JWT access and refresh tokens."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"user\": {\n    \"id\": 1,\n    \"first_name\": \"Sophia\",\n    \"last_name\": \"Bennett\",\n    \"email\": \"sophia.bennett@example.com\",\n    \"date_joined\": \"2024-06-01T10:00:00Z\"\n  },\n  \"access\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"refresh\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n}"
            }
          ]
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.access) {",
                  "    pm.collectionVariables.set('access_token', json.access);",
                  "    console.log('✅ access_token saved to collection variables.');",
                  "} else {",
                  "    console.warn('⚠️  No access token found in response.');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"sophia.bennett@example.com\",\n  \"password\": \"SecurePass@2024\"\n}"
            },
            "description": "Authenticates a user with email and password. On success the **Tests** script automatically saves the returned `access` token into the `{{access_token}}` collection variable for use in all protected requests."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"access\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"refresh\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"id\": 1,\n    \"email\": \"sophia.bennett@example.com\",\n    \"first_name\": \"Sophia\",\n    \"last_name\": \"Bennett\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n}"
            },
            "description": "Blacklists the provided refresh token, effectively logging the user out. Requires a valid access token in the Authorization header."
          },
          "response": [
            {
              "name": "205 Reset Content",
              "status": "Reset Content",
              "code": 205,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"detail\": \"Successfully logged out.\"\n}"
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/token/refresh",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "token", "refresh"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n}"
            },
            "description": "Issues a new short-lived access token using a valid refresh token. Use this when the access token expires (typically after 5–15 minutes)."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"access\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\"\n}"
            }
          ]
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Returns the profile details of the currently authenticated user. Requires a valid Bearer token."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"first_name\": \"Sophia\",\n  \"last_name\": \"Bennett\",\n  \"email\": \"sophia.bennett@example.com\",\n  \"phone\": \"+1-555-0199\",\n  \"date_joined\": \"2024-06-01T10:00:00Z\",\n  \"is_active\": true\n}"
            }
          ]
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/me/update",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "me", "update"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"first_name\": \"Sophia\",\n  \"last_name\": \"Clarke\",\n  \"phone\": \"+1-555-0199\",\n  \"address\": {\n    \"street\": \"742 Evergreen Terrace\",\n    \"city\": \"Springfield\",\n    \"state\": \"IL\",\n    \"zip\": \"62704\",\n    \"country\": \"US\"\n  }\n}"
            },
            "description": "Updates profile fields for the authenticated user. Only provided fields are changed (partial updates also accepted via PATCH if supported)."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"id\": 1,\n  \"first_name\": \"Sophia\",\n  \"last_name\": \"Clarke\",\n  \"email\": \"sophia.bennett@example.com\",\n  \"phone\": \"+1-555-0199\",\n  \"address\": {\n    \"street\": \"742 Evergreen Terrace\",\n    \"city\": \"Springfield\",\n    \"state\": \"IL\",\n    \"zip\": \"62704\",\n    \"country\": \"US\"\n  }\n}"
            }
          ]
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/change-password",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "change-password"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"old_password\": \"SecurePass@2024\",\n  \"new_password\": \"NewSecurePass@2025\",\n  \"new_password_confirm\": \"NewSecurePass@2025\"\n}"
            },
            "description": "Changes the password for the authenticated user. Requires the current password for verification. All existing refresh tokens are invalidated after a successful change."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"detail\": \"Password updated successfully.\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Categories",
      "description": "Endpoints for listing product categories and browsing products within a category.",
      "item": [
        {
          "name": "List All Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/categories",
              "host": ["{{base_url}}"],
              "path": ["api", "categories"]
            },
            "description": "Returns a flat list of all active product categories. No authentication required. Useful for building navigation menus."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"count\": 3,\n  \"results\": [\n    {\n      \"id\": 1,\n      \"name\": \"Watches\",\n      \"slug\": \"watches\",\n      \"description\": \"Luxury timepieces from the world's finest brands.\",\n      \"image\": \"https://cdn.luxemarket.com/categories/watches.jpg\",\n      \"product_count\": 48\n    },\n    {\n      \"id\": 2,\n      \"name\": \"Handbags\",\n      \"slug\": \"handbags\",\n      \"description\": \"Designer handbags crafted with premium materials.\",\n      \"image\": \"https://cdn.luxemarket.com/categories/handbags.jpg\",\n      \"product_count\": 35\n    },\n    {\n      \"id\": 3,\n      \"name\": \"Jewellery\",\n      \"slug\": \"jewellery\",\n      \"description\": \"Fine jewellery for every occasion.\",\n      \"image\": \"https://cdn.luxemarket.com/categories/jewellery.jpg\",\n      \"product_count\": 22\n    }\n  ]\n}"
            }
          ]
        },
