          "name": "List All Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/products",
              "host": ["{{base_url}}"],
              "path": ["api", "products"],
              "query": [
                { "key": "page", "value": "1", "disabled": true },
                { "key": "page_size", "value": "12", "disabled": true },
